{
  "name": "aetheris-studio-webgl-hero",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "qa:contrast": "npm run build && node qa/dynamic-contrast.mjs",
    "qa:consent": "node qa/consent-network.mjs",
    "test": "vitest run && npm run test:legacy",
    "test:legacy": "node --test tests/*.test.mjs",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/fiber": "9.6.1",
    "react": "19.2.8",
    "react-dom": "19.2.8",
    "three": "0.185.1"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
