# ───────────────────────────────────────────────────────────────────
# Aetheris Solutions — environment variables
# Copy this file to `.env.local` and fill in the values you need.
# ───────────────────────────────────────────────────────────────────

# Where contact submissions are delivered.
# Defaults to maru@hey.com if not set.
CONTACT_TO_EMAIL=maru@hey.com

# ── Email provider (priority: Resend > Web3Forms > FormSubmit) ─────
# Configure ONE of these. If none set, the system falls back to
# FormSubmit.co (zero-config, requires one-time email confirmation).

# Resend (recommended for production) — https://resend.com
# Free tier: 3,000 emails/month
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=Aetheris Solutions <hello@aetheris.solutions>

# Web3Forms — https://web3forms.com (free, no signup, just an access key)
# WEB3FORMS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Supabase persistence (optional) ───────────────────────────────
# When set, every contact submission is stored in the
# `contact_submissions` table. Run `supabase/schema.sql` in the
# Supabase SQL editor first.
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# SUPABASE_TABLE=contact_submissions
